---
interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = "Ignacio Norambuena — Ing. Civil Informático UTFSM, CTO de Zentia. 8 años de experiencia en software, IoT minero y automatización industrial.",
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Person",
  name: "Ignacio Norambuena",
  url: "https://archidemus.me",
  jobTitle: "CTO",
  worksFor: {
    "@type": "Organization",
    name: "Zentia",
    description: "Sistema de monitoreo del ciclo minero basado en IoT",
  },
  alumniOf: {
    "@type": "CollegeOrUniversity",
    name: "Universidad Técnica Federico Santa María",
    alternateName: "UTFSM",
  },
  knowsAbout: [
    "Internet of Things",
    "Embedded Systems",
    "Full-Stack Development",
    "React",
    "TypeScript",
    "C++",
    "Python",
    "Mining Technology",
    "Industrial Automation",
  ],
  sameAs: ["https://www.linkedin.com/in/inorambuenaa", "https://github.com/archidemus"],
  email: "ignacio@archidemus.me",
};
---

<!doctype html>
<html lang="es" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="index, follow" />
    <meta name="author" content="Ignacio Norambuena" />
    <link rel="icon" type="image/icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>

    <link rel="canonical" href={canonicalURL} />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="es_CL" />
    <meta property="og:site_name" content="Ignacio Norambuena" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <script type="application/ld+json" is:inline set:html={JSON.stringify(jsonLd)} />
  </head>
  <body>
    <slot />
  </body>
</html>
<style is:global>
  body {
    min-height: 100%;
  }
  html {
    scroll-behavior: smooth;
  }
</style>
