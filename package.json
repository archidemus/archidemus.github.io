{
  "name": "desktop-aiwalk",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "astro check && astro build",
    "preview": "astro preview",
    "astro": "astro",
    "format": "prettier --write \"src/**/*.{astro,tsx,ts,css,mjs}\"",
    "format:check": "prettier --check \"src/**/*.{astro,tsx,ts,css,mjs}\"",
    "lint": "eslint \"src/**/*.{ts,tsx,astro}\"",
    "lint:fix": "eslint --fix \"src/**/*.{ts,tsx,astro}\"",
    "check": "prettier --check \"src/**/*.{astro,tsx,ts,css,mjs}\" && eslint \"src/**/*.{ts,tsx,astro}\" && astro check && astro build",
    "fix": "prettier --write \"src/**/*.{astro,tsx,ts,css,mjs}\" && eslint --fix \"src/**/*.{ts,tsx,astro}\""
  },
  "dependencies": {
    "@astrojs/check": "^0.9.9",
    "@astrojs/react": "^3.6.3",
    "@astrojs/tailwind": "^5.1.5",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "astro": "^4.16.19",
    "lucide-react": "^1.14.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwindcss": "^3.4.19",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^5.9.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.3.0",
    "eslint-plugin-astro": "^1.7.0",
    "eslint-plugin-react": "^7.37.5",
    "prettier": "^3.8.3",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "typescript-eslint": "^8.59.2"
  }
}
